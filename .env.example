# --- Convex deployment ---
# Set automatically by `npx convex dev` (writes to .env.local, not this file).
# Listed here for reference; .env.local is gitignored.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=

# --- Site URL ---
# Public URL of the frontend (no trailing slash).
# Must match between .env.local (Vite) and Convex env (SITE_URL).
# Example:  https://guides-tours.fuurma.tech
VITE_SITE_URL=http://localhost:3000
# Backend equivalent — set on Convex dashboard:
#   npx convex env set SITE_URL=https://guides-tours.fuurma.tech
SITE_URL=

# --- Better Auth ---
# Generate with: openssl rand -base64 32
# Set on Convex dashboard: `npx convex env set BETTER_AUTH_SECRET=...`
BETTER_AUTH_SECRET=

# --- Email (Amazon SES) — Phase 7 ---
# NOTE: this repo's code reads AWS_REGION/AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY/SES_FROM_ADDRESS.
# tech-stack/CONVENTIONS.md documents the standard as AWS_SES_REGION/AWS_SES_ACCESS_KEY_ID/AWS_SES_SECRET_ACCESS_KEY/SES_FROM_EMAIL.
# The .env.example matches what the code actually reads — do not change these names without also renaming every process.env.* reference.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_ADDRESS=

# --- Stripe — Phase 8 ---
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- OTA credentials — Phase 6 ---
OTA_VIATOR_API_KEY=
OTA_GETYOURGUIDE_API_KEY=
OTA_GETYOURGUIDE_PARTNER_ID=
OTA_AIRBNB_API_KEY=
OTA_AIRBNB_API_SECRET=
OTA_TRIPADVISOR_API_KEY=
OTA_TRIPADVISOR_PARTNER_ID=
OTA_TRIPADVISOR_API_SECRET=
OTA_KLOOK_API_KEY=
OTA_KLOOK_API_SECRET=
OTA_BOOKING_API_KEY=
OTA_BOOKING_API_SECRET=
OTA_EXPEDIA_API_KEY=
OTA_EXPEDIA_API_SECRET=

# --- At-rest encryption for OTA + Stripe secrets — Phase 3 ---
# Must be 32 bytes (64 hex chars) or 32 raw chars.
# Generate with:  openssl rand -hex 32
# Set on Convex dashboard:  npx convex env set ENCRYPTION_KEY=...
ENCRYPTION_KEY=

# --- Public booking origin allowlist ---
# Comma-separated origins allowed to POST /api/public/book/:slug.
# If unset, all origins are allowed (development-friendly default).
# Example: https://tours.example.com,https://www.example.com
PUBLIC_BOOKING_ALLOWED_ORIGINS=